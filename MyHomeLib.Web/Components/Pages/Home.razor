@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LibraryService Library

<PageTitle>Book Search — MyHomeLib</PageTitle>

<h1 class="h4 mb-4">Search Books</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (!libraryReady)
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading library, please wait…</span>
    </div>
}
else if (!indexReady)
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Building search index…</span>
    </div>
}

<div class="input-group mb-3">
    <input class="form-control"
           placeholder="Search by title, author or series…"
           @bind="searchQuery"
           @bind:event="oninput"
           @onkeydown="OnKeyDown" />
    <button class="btn btn-primary" @onclick="Search" disabled="@(!indexReady)">Search</button>
</div>

@if (results is not null)
{
    <p class="text-muted small mb-2">
        Showing @results.Value.Page.Count of @results.Value.Total
        @(results.Value.Total == 1 ? "result" : "results")
    </p>

    @if (results.Value.Page.Count == 0)
    {
        <p class="text-muted">No books found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Authors</th>
                        <th>Series</th>
                        <th>Lang</th>
                        <th>File</th>
                        <th>Archive</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in results.Value.Page)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>
                                @foreach (var author in book.ParsedAuthors())
                                {
                                    <div>@author</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(book.Series))
                                {
                                    @book.Series
                                    @if (!string.IsNullOrEmpty(book.SeriesNo))
                                    {
                                        <span class="text-muted"> #@book.SeriesNo</span>
                                    }
                                }
                            </td>
                            <td>@book.Lang</td>
                            <td class="text-muted small font-monospace">@(book.File + "." + book.Ext)</td>
                            <td class="text-muted small font-monospace">@book.ArchiveFile</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    string searchQuery = "";

    (IReadOnlyList<BookItem> Page, int Total)? results;
    bool libraryReady;
    bool indexReady;
    string? errorMessage;

    protected override void OnInitialized()
    {
        libraryReady = Library.LoadTask.IsCompletedSuccessfully;
        indexReady   = Library.IndexTask.IsCompletedSuccessfully;

        if (Library.LoadTask.IsFaulted)
            errorMessage = Library.LoadTask.Exception?.GetBaseException().Message;
        else if (Library.IndexTask.IsFaulted)
            errorMessage = Library.IndexTask.Exception?.GetBaseException().Message;
        else if (!indexReady)
            _ = WatchProgress();
    }

    async Task WatchProgress()
    {
        try
        {
            await Library.LoadTask;
            libraryReady = true;
            await InvokeAsync(StateHasChanged);

            await Library.IndexTask;
            indexReady = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        await InvokeAsync(StateHasChanged);
    }

    async Task Search()
    {
        if (!indexReady) return;
        results = await Library.SearchAsync(searchQuery);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }
}
