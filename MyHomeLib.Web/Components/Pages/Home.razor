@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LibraryService Library
@inject DownloadQueueService Queue
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject UserSessionContext UserSession
@inject SearchPageState SearchState
@inject IJSRuntime JS
@implements IDisposable
@using Humanizer
@using System.Diagnostics

<PageTitle>Book Search — MyHomeLib</PageTitle>

<MudText Typo="Typo.h5" Class="page-title">Search Books</MudText>

@if (errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
}
else if (!indexReady)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        <div class="d-flex align-items-center gap-2">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            @Library.LoadStatus
        </div>
    </MudAlert>
}

@if (indexReady)
{
    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <MudChip T="string" Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary"
                 Variant="Variant.Outlined" Size="Size.Small" Class="ma-0">
            @Library.TotalBooks.ToString("N0") books
        </MudChip>
        @if (!string.IsNullOrEmpty(Library.Metadata.Description))
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Library.Metadata.Description</MudText>
        }
        @if (!string.IsNullOrEmpty(Library.Metadata.Version))
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="ma-0">
                v@Library.Metadata.Version
            </MudChip>
        }
        @if (!string.IsNullOrEmpty(Library.MagnetUri))
        {
            <MudTooltip Text="@Library.MagnetUri">
                <MudIconButton Icon="@Icons.Material.Filled.Link" Size="Size.Small"
                               Href="@Library.MagnetUri" aria-label="Magnet link" />
            </MudTooltip>
        }
    </div>
}

<div class="d-flex align-items-center gap-2 mb-2">
    <MudTextField T="string"
                  Value="@searchQuery"
                  Placeholder="Search by title, author or series..."
                  Variant="Variant.Outlined"
                  FullWidth="true"
                  Adornment="@(_searching ? Adornment.End : Adornment.None)"
                  AdornmentIcon="@Icons.Material.Filled.HourglassTop"
                  Clearable="true"
                  Disabled="@(!indexReady)"
                  OnKeyDown="OnKeyDown"
                  ValueChanged="OnValueChanged"
                  Class="mb-0"
                  Style="min-width: 0;" />

    <MudSelect T="string"
               Value="@selectedLanguage"
               ValueChanged="OnLanguageChanged"
               Placeholder="Lang"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Disabled="@(!indexReady)"
               Class="mb-0"
               Style="width: 130px;">
        <MudSelectItem T="string" Value="@AllLanguagesValue">All</MudSelectItem>
        @foreach (var lang in languages)
        {
            <MudSelectItem T="string" Value="@lang">@lang</MudSelectItem>
        }
    </MudSelect>
</div>

@if (_searchMs.HasValue && results.HasValue)
{
    <MudText Typo="Typo.caption" Class="results-meta">
        @results.Value.Total @(results.Value.Total == 1 ? "result" : "results") — @_searchMs ms
    </MudText>
}

@if (results is { Page.Count: 0 } && !_searching && !string.IsNullOrWhiteSpace(searchQuery))
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">No books found.</MudAlert>
}

@if (results is { Page.Count: > 0 } r)
{
    <MudTable Items="@r.Page" Hover="true" Dense="true" Striped="true"
              Breakpoint="Breakpoint.Sm" FixedHeader="true" Height="600px"
              Class="mb-2 books-table">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Authors</MudTh>
            <MudTh>Series</MudTh>
            <MudTh>Lang</MudTh>
            <MudTh>File</MudTh>
            <MudTh>Archive</MudTh>
            @if (Queue.IsEnabled) { <MudTh></MudTh> }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Authors">
                @foreach (var author in context.ParsedAuthors())
                {
                    <div>@author</div>
                }
            </MudTd>
            <MudTd DataLabel="Series">
                @if (!string.IsNullOrEmpty(context.Series))
                {
                    @context.Series
                    @if (!string.IsNullOrEmpty(context.SeriesNo))
                    {
                        <MudText Inline="true" Typo="Typo.caption" Class="ml-1 mud-text-secondary">#@context.SeriesNo</MudText>
                    }
                }
            </MudTd>
            <MudTd DataLabel="Lang">@context.Lang</MudTd>
            <MudTd DataLabel="File">
                <MudText Typo="Typo.caption" Class="mono-text">@(context.File + "." + context.Ext)</MudText>
            </MudTd>
            <MudTd DataLabel="Archive">
                <MudText Typo="Typo.caption" Class="mono-text">@context.ArchiveFile</MudText>
            </MudTd>
            @if (Queue.IsEnabled)
            {
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                   Size="Size.Small"
                                   aria-label="Queue download"
                                   OnClick="() => Enqueue(context)" />
                </MudTd>
            }
        </RowTemplate>
    </MudTable>

    @if (r.Total > r.Page.Count)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Showing top @r.Page.Count of @r.Total results. Refine your query to narrow results.
        </MudText>
    }
}

@code {
    string searchQuery = "";
    const string AllLanguagesValue = "__all__";
    string selectedLanguage = AllLanguagesValue;
    List<string> languages = [];
    PeriodicTimer? _loadTimer;
    CancellationTokenSource? _searchCts;

    (IReadOnlyList<BookItem> Page, int Total)? results;
    bool indexReady;
    string? errorMessage;
    bool _searching;
    long? _searchMs;

    protected override void OnInitialized()
    {
        _ = EnsureUserSessionAsync();

        searchQuery = SearchState.Query;
        selectedLanguage = string.IsNullOrWhiteSpace(SearchState.Language) ? AllLanguagesValue : SearchState.Language;
        results = SearchState.Results;
        _searchMs = SearchState.SearchMs;

        indexReady = Library.IndexTask.IsCompletedSuccessfully;

        if (indexReady)
            _ = LoadLanguagesAsync();

        if (Library.IndexTask.IsFaulted)
            errorMessage = Library.IndexTask.Exception?.GetBaseException().Message;
        else if (!indexReady)
            _ = WatchProgress();
        if (!indexReady)
            _ = PollLoad();
    }

    async Task WatchProgress()
    {
        _loadTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            await Library.IndexTask;
            indexReady = true;
            await LoadLanguagesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        _loadTimer.Dispose();
        _loadTimer = null;
        await InvokeAsync(StateHasChanged);
    }

    async Task PollLoad()
    {
        while (_loadTimer is not null && await _loadTimer.WaitForNextTickAsync())
            await InvokeAsync(StateHasChanged);
    }

    async Task OnValueChanged(string value)
    {
        searchQuery = value;
        SearchState.Query = value;
        await TriggerSearch(debounceMs: 300);
    }

    async Task OnLanguageChanged(string value)
    {
        selectedLanguage = value;
        SearchState.Language = selectedLanguage == AllLanguagesValue ? string.Empty : selectedLanguage;

        if (!string.IsNullOrWhiteSpace(searchQuery))
            await TriggerSearch(debounceMs: 0);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await TriggerSearch(debounceMs: 0);
    }

    async Task TriggerSearch(int debounceMs)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;

        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            results = null;
            _searchMs = null;
            _searching = false;
            SearchState.Clear();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!indexReady) return;

        if (debounceMs > 0)
        {
            try { await Task.Delay(debounceMs, cts.Token); }
            catch (OperationCanceledException) { return; }
        }

        if (cts.IsCancellationRequested) return;

        _searching = true;
        await InvokeAsync(StateHasChanged);

        var sw = Stopwatch.StartNew();
        try
        {
            var r = await Library.SearchAsync(searchQuery, selectedLanguage == AllLanguagesValue ? null : selectedLanguage);
            sw.Stop();
            if (!cts.IsCancellationRequested)
            {
                results = r;
                _searchMs = sw.ElapsedMilliseconds;
                SearchState.Query = searchQuery;
                SearchState.Language = selectedLanguage == AllLanguagesValue ? string.Empty : selectedLanguage;
                SearchState.Results = results;
                SearchState.SearchMs = _searchMs;
            }
        }
        catch (Exception ex) when (!cts.IsCancellationRequested)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            if (!cts.IsCancellationRequested)
                _searching = false;
        }

        if (!cts.IsCancellationRequested)
            await InvokeAsync(StateHasChanged);
    }

    async Task Enqueue(BookItem book)
    {
        await EnsureUserSessionAsync();

        if (string.IsNullOrWhiteSpace(UserSession.UserId))
        {
            Snackbar.Add("Session is not ready yet, please try again.", Severity.Warning);
            return;
        }

        await Queue.EnqueueAsync(book, UserSession.UserId);
        Snackbar.Add($"Queued: {book.Title}", Severity.Success);
        NavigationManager.NavigateTo("/downloads");
    }

    async Task LoadLanguagesAsync()
    {
        try
        {
            languages = (await Library.GetLanguagesAsync()).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            languages = [];
        }
    }

    async Task EnsureUserSessionAsync()
    {
        if (UserSession.IsLoaded)
            return;

        try
        {
            var userId = await JS.InvokeAsync<string?>("myHomeLibSession.getOrCreateUserId");
            if (!string.IsNullOrWhiteSpace(userId))
                UserSession.SetUserId(userId);
        }
        catch
        {
            // Keep empty user id; UI already guards queue actions.
        }
    }

    public void Dispose()
    {
        _loadTimer?.Dispose();
        _searchCts?.Cancel();
    }
}
