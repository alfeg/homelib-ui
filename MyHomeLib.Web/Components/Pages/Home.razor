@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LibraryService Library
@inject DownloadQueueService Queue
@implements IDisposable
@using Humanizer
@using System.Diagnostics

<PageTitle>Book Search — MyHomeLib</PageTitle>

<h1 class="h4 mb-4">Search Books</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (!indexReady)
{
    <div class="alert alert-info d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>@Library.LoadStatus</span>
    </div>
}

<div class="input-group mb-1">
    <input class="form-control"
           placeholder="Search by title, author or series…"
           value="@searchQuery"
           @oninput="OnInput"
           @onkeydown="OnKeyDown"
           disabled="@(!indexReady)" />
    @if (_searching)
    {
        <span class="input-group-text">
            <span class="spinner-border spinner-border-sm" role="status"></span>
        </span>
    }
</div>

@if (results is not null || _searchMs.HasValue)
{
    <p class="text-muted small mb-2">
        @if (_searchMs.HasValue && results.HasValue)
        {
            <span>@results.Value.Total @(results.Value.Total == 1 ? "result" : "results") — @_searchMs ms</span>
        }
    </p>
}

@if (lastQueued is not null)
{
    <div class="alert alert-success alert-dismissible py-2 mb-3" role="alert">
        Book queued for download. <a href="/downloads">View downloads →</a>
        <button type="button" class="btn-close" @onclick="() => lastQueued = null"></button>
    </div>
}

@if (results is { } r && r.Page.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-sm table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Authors</th>
                    <th>Series</th>
                    <th>Lang</th>
                    <th>File</th>
                    <th>Archive</th>
                    @if (Queue.IsEnabled) { <th></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var book in r.Page)
                {
                    <tr>
                        <td>@book.Title</td>
                        <td>
                            @foreach (var author in book.ParsedAuthors())
                            {
                                <div>@author</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(book.Series))
                            {
                                @book.Series
                                @if (!string.IsNullOrEmpty(book.SeriesNo))
                                {
                                    <span class="text-muted"> #@book.SeriesNo</span>
                                }
                            }
                        </td>
                        <td>@book.Lang</td>
                        <td class="text-muted small font-monospace">@(book.File + "." + book.Ext)</td>
                        <td class="text-muted small font-monospace">@book.ArchiveFile</td>
                        @if (Queue.IsEnabled)
                        {
                            <td>
                                <button class="btn btn-sm btn-outline-secondary"
                                        title="Queue download"
                                        @onclick="() => Enqueue(book)">⬇</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (r.Total > r.Page.Count)
    {
        <p class="text-muted small">Showing top @r.Page.Count of @r.Total results. Refine your query to narrow results.</p>
    }
}
else if (results is { Page.Count: 0 } && !_searching)
{
    <p class="text-muted">No books found.</p>
}

@code {
    string searchQuery = "";
    Guid? lastQueued;
    PeriodicTimer? _loadTimer;
    CancellationTokenSource? _searchCts;

    (IReadOnlyList<BookItem> Page, int Total)? results;
    bool indexReady;
    string? errorMessage;
    bool _searching;
    long? _searchMs;

    protected override void OnInitialized()
    {
        indexReady = Library.IndexTask.IsCompletedSuccessfully;

        if (Library.IndexTask.IsFaulted)
            errorMessage = Library.IndexTask.Exception?.GetBaseException().Message;
        else if (!indexReady)
            _ = WatchProgress();
        if (!indexReady)
            _ = PollLoad();
    }

    async Task WatchProgress()
    {
        _loadTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            await Library.IndexTask;
            indexReady = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        _loadTimer.Dispose();
        _loadTimer = null;
        await InvokeAsync(StateHasChanged);
    }

    async Task PollLoad()
    {
        while (_loadTimer is not null && await _loadTimer.WaitForNextTickAsync())
            await InvokeAsync(StateHasChanged);
    }

    async Task OnInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
        await TriggerSearch(debounceMs: 300);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await TriggerSearch(debounceMs: 0);
    }

    async Task TriggerSearch(int debounceMs)
    {
        // Cancel any in-flight debounce/search
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;

        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            results = null;
            _searchMs = null;
            _searching = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!indexReady) return;

        if (debounceMs > 0)
        {
            try { await Task.Delay(debounceMs, cts.Token); }
            catch (OperationCanceledException) { return; }
        }

        if (cts.IsCancellationRequested) return;

        _searching = true;
        lastQueued = null;
        await InvokeAsync(StateHasChanged);

        var sw = Stopwatch.StartNew();
        try
        {
            var r = await Library.SearchAsync(searchQuery);
            sw.Stop();
            if (!cts.IsCancellationRequested)
            {
                results = r;
                _searchMs = sw.ElapsedMilliseconds;
            }
        }
        catch (Exception ex) when (!cts.IsCancellationRequested)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            if (!cts.IsCancellationRequested)
                _searching = false;
        }

        if (!cts.IsCancellationRequested)
            await InvokeAsync(StateHasChanged);
    }

    async Task Enqueue(BookItem book)
    {
        lastQueued = await Queue.EnqueueAsync(book);
    }

    public void Dispose()
    {
        _loadTimer?.Dispose();
        _searchCts?.Cancel();
    }
}
