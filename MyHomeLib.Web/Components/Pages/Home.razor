@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LibraryService Library
@inject DownloadQueueService Queue
@implements IDisposable
@using Humanizer

<PageTitle>Book Search — MyHomeLib</PageTitle>

<h1 class="h4 mb-4">Search Books</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (!indexReady)
{
    <div class="alert alert-info">
        <div class="d-flex align-items-center gap-2 mb-1">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <span>@Library.LoadStatus</span>
        </div>
        @if (Library.InpxStats is { } s)
        {
            <div class="mt-2 ms-1" style="font-size:0.8rem">
                @if (s.State == "Metadata")
                {
                    <div>Fetching torrent metadata via DHT…
                        <span class="ms-2">🌐 @s.DhtNodes nodes (@s.DhtState)</span>
                        <span class="ms-2">👤 @s.Seeds seeds / @s.Peers peers</span>
                    </div>
                }
                else
                {
                    <div class="progress mb-1" style="height:5px;max-width:400px" title="@s.PartialProgress.ToString("0.0")%">
                        <div class="progress-bar" style="width:@s.PartialProgress.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="d-flex gap-3">
                        <span>⬇ @FormatRate(s.DownloadRateBytesPerSec)</span>
                        <span>🌱 @s.Seeds / @s.Peers</span>
                        <span>🌐 @s.DhtNodes (@s.DhtState)</span>
                    </div>
                }
            </div>
        }
    </div>
}

<div class="input-group mb-3">
    <input class="form-control"
           placeholder="Search by title, author or series…"
           @bind="searchQuery"
           @bind:event="oninput"
           @onkeydown="OnKeyDown" />
    <button class="btn btn-primary" @onclick="Search" disabled="@(!indexReady)">Search</button>
</div>

@if (lastQueued is not null)
{
    <div class="alert alert-success alert-dismissible py-2 mb-3" role="alert">
        Book queued for download. <a href="/downloads">View downloads →</a>
        <button type="button" class="btn-close" @onclick="() => lastQueued = null"></button>
    </div>
}

@if (results is not null)
{
    <p class="text-muted small mb-2">
        Showing @results.Value.Page.Count of @results.Value.Total
        @(results.Value.Total == 1 ? "result" : "results")
    </p>

    @if (results.Value.Page.Count == 0)
    {
        <p class="text-muted">No books found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Authors</th>
                        <th>Series</th>
                        <th>Lang</th>
                        <th>File</th>
                        <th>Archive</th>
                        @if (Queue.IsEnabled) { <th></th> }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in results.Value.Page)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>
                                @foreach (var author in book.ParsedAuthors())
                                {
                                    <div>@author</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(book.Series))
                                {
                                    @book.Series
                                    @if (!string.IsNullOrEmpty(book.SeriesNo))
                                    {
                                        <span class="text-muted"> #@book.SeriesNo</span>
                                    }
                                }
                            </td>
                            <td>@book.Lang</td>
                            <td class="text-muted small font-monospace">@(book.File + "." + book.Ext)</td>
                            <td class="text-muted small font-monospace">@book.ArchiveFile</td>
                            @if (Queue.IsEnabled)
                            {
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            title="Queue download"
                                            @onclick="() => Enqueue(book)">⬇</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    string searchQuery = "";
    Guid? lastQueued;
    PeriodicTimer? _loadTimer;

    (IReadOnlyList<BookItem> Page, int Total)? results;
    bool indexReady;
    string? errorMessage;

    protected override void OnInitialized()
    {
        indexReady   = Library.IndexTask.IsCompletedSuccessfully;

        if (Library.IndexTask.IsFaulted)
            errorMessage = Library.IndexTask.Exception?.GetBaseException().Message;
        else if (!indexReady)
            _ = WatchProgress();
        if (!indexReady)
            _ = PollLoad();
    }

    async Task WatchProgress()
    {
        // Poll every second while loading so LoadStatus / InpxStats stay current
        _loadTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            await Library.IndexTask;
            indexReady = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        _loadTimer.Dispose();
        _loadTimer = null;
        await InvokeAsync(StateHasChanged);
    }

    // Drives the re-render loop while loading
    async Task PollLoad()
    {
        while (_loadTimer is not null && await _loadTimer.WaitForNextTickAsync())
            await InvokeAsync(StateHasChanged);
    }

    async Task Search()
    {
        if (!indexReady) return;
        lastQueued = null;
        results = await Library.SearchAsync(searchQuery);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    async Task Enqueue(BookItem book)
    {
        lastQueued = await Queue.EnqueueAsync(book);
    }

    static string FormatRate(double bytesPerSec) =>
        bytesPerSec < 1 ? "0 B/s" : $"{((long)bytesPerSec).Bytes().Humanize("#.#")}/s";

    public void Dispose() => _loadTimer?.Dispose();
}
