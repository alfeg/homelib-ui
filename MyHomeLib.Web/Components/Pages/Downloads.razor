@page "/downloads"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject DownloadQueueService Queue
@inject UserSessionContext UserSession
@implements IDisposable

<PageTitle>Downloads — MyHomeLib</PageTitle>

<MudText Typo="Typo.h5" Class="page-title">Downloads</MudText>

@if (!Queue.IsEnabled)
{
    <MudAlert Severity="Severity.Warning">
        Torrent downloads are not configured. Set <code>Library:MagnetUri</code> and
        <code>Library:DownloadsDirectory</code> in your configuration.
    </MudAlert>
}
else if (jobs.Count == 0)
{
    <MudText Class="mud-text-secondary">No downloads yet. Search for a book and click the download icon to queue it.</MudText>
}
else
{
    <MudTable Items="@jobs" Hover="true" Dense="true" Striped="true"
              Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Authors</MudTh>
            <MudTh>File</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Added</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Authors">
                <MudText Typo="Typo.caption">@context.Authors</MudText>
            </MudTd>
            <MudTd DataLabel="File">
                <MudText Typo="Typo.caption" Class="mono-text">@context.FileName</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @switch (context.Status)
                {
                    case DownloadStatus.Pending:
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Pending</MudChip>
                        break;
                    case DownloadStatus.Downloading:
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            Downloading
                        </MudChip>
                        break;
                    case DownloadStatus.Ready:
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Ready</MudChip>
                        break;
                    case DownloadStatus.Failed:
                        <MudTooltip Text="@(context.Error ?? "Unknown error")">
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Failed</MudChip>
                        </MudTooltip>
                        @if (!string.IsNullOrEmpty(context.Error))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@context.Error</MudText>
                        }
                        break;
                }
            </MudTd>
            <MudTd DataLabel="Added">
                <MudText Typo="Typo.caption">@context.AddedAt.ToLocalTime().ToString("g")</MudText>
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    @if (context.Status == DownloadStatus.Ready)
                    {
                        <MudButton Href="@($"/api/download/{context.Id}")"
                                   download="@context.DownloadName"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   Color="Color.Success"
                                   Variant="Variant.Filled"
                                   Size="Size.Small">Get</MudButton>
                    }
                    <MudIconButton Icon="@(context.Status == DownloadStatus.Downloading ? Icons.Material.Filled.Stop : Icons.Material.Filled.Close)"
                                   Color="@(context.Status == DownloadStatus.Downloading ? Color.Warning : Color.Error)"
                                   Size="Size.Small"
                                   aria-label="@(context.Status == DownloadStatus.Downloading ? "Abort" : "Remove")"
                                   OnClick="() => Delete(context.Id)" />
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    List<DownloadJob> jobs = [];
    PeriodicTimer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync();
    }

    async Task PollAsync()
    {
        if (_timer is null) return;
        while (await _timer.WaitForNextTickAsync())
        {
            await Refresh();
            await InvokeAsync(StateHasChanged);
            if (!jobs.Any(j => j.Status is DownloadStatus.Pending or DownloadStatus.Downloading)
                && Queue.ActiveStats.Count == 0)
                _timer.Dispose();
        }
    }

    async Task Refresh()
    {
        if (string.IsNullOrWhiteSpace(UserSession.UserId))
        {
            jobs = [];
            return;
        }

        jobs = (await Queue.GetAllAsync(UserSession.UserId)).ToList();
    }

    async Task Delete(Guid id)
    {
        if (string.IsNullOrWhiteSpace(UserSession.UserId))
            return;

        await Queue.DeleteAsync(id, UserSession.UserId);
        await Refresh();
        _timer?.Dispose();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync();
    }

    public void Dispose() => _timer?.Dispose();
}
