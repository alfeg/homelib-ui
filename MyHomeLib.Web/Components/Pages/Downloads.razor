@page "/downloads"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject DownloadQueueService Queue
@implements IDisposable
@using Humanizer

<PageTitle>Downloads — MyHomeLib</PageTitle>

<h1 class="h4 mb-4">Downloads</h1>

@if (!Queue.IsEnabled)
{
    <div class="alert alert-warning">
        Torrent downloads are not configured. Set <code>Library:MagnetUri</code> and
        <code>Library:DownloadsDirectory</code> in your configuration.
    </div>
}
else if (jobs.Count == 0)
{
    <p class="text-muted">No downloads yet. Search for a book and click ⬇ to queue it.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Authors</th>
                    <th>File</th>
                    <th style="min-width:220px">Status</th>
                    <th>Added</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in jobs)
                {
                    var stats = Queue.ActiveStats.GetValueOrDefault(job.Id);
                    <tr>
                        <td>@job.Title</td>
                        <td class="text-muted small">@job.Authors</td>
                        <td class="font-monospace small">@job.FileName</td>
                        <td>
                            @switch (job.Status)
                            {
                                case DownloadStatus.Pending:
                                    <span class="badge bg-secondary">Pending</span>
                                    break;
                                case DownloadStatus.Downloading:
                                    <div>
                                        <span class="badge bg-primary mb-1">
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            Downloading
                                        </span>
                                        @if (stats is not null)
                                        {
                                            <div class="mt-1">
                                                <div class="progress mb-1" style="height:6px" title="@stats.PartialProgress.ToString("0.0")%">
                                                    <div class="progress-bar" role="progressbar"
                                                         style="width:@stats.PartialProgress.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                                </div>
                                                <div class="d-flex gap-2 text-muted" style="font-size:0.75rem">
                                                    <span title="Download speed">⬇ @FormatRate(stats.DownloadRateBytesPerSec)</span>
                                                    <span title="Upload speed">⬆ @FormatRate(stats.UploadRateBytesPerSec)</span>
                                                    <span title="Seeds / Peers">🌱 @stats.Seeds / @stats.Peers</span>
                                                    <span title="Bytes received">@stats.BytesReceived.Bytes().Humanize("#.#")</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    break;
                                case DownloadStatus.Ready:
                                    <span class="badge bg-success">Ready</span>
                                    break;
                                case DownloadStatus.Failed:
                                    <span class="badge bg-danger" title="@job.Error">Failed ⓘ</span>
                                    @if (!string.IsNullOrEmpty(job.Error))
                                    {
                                        <div class="text-danger small mt-1" style="max-width:300px;word-break:break-word">@job.Error</div>
                                    }
                                    break;
                            }
                        </td>
                        <td class="text-muted small text-nowrap">@job.AddedAt.ToLocalTime().ToString("g")</td>
                        <td class="text-nowrap">
                            <div class="d-flex gap-1">
                                @if (job.Status == DownloadStatus.Ready)
                                {
                                    <a class="btn btn-sm btn-success"
                                       href="/api/download/@job.Id"
                                       download="@job.DownloadName">⬇ Get</a>
                                }
                                @{
                                    var isActive = job.Status is DownloadStatus.Downloading;
                                    var btnLabel = isActive ? "⏹ Abort" : "✕";
                                    var btnClass = isActive ? "btn btn-sm btn-warning" : "btn btn-sm btn-outline-danger";
                                }
                                <button class="@btnClass" @onclick="() => Delete(job.Id)">@btnLabel</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    List<DownloadJob> jobs = [];
    PeriodicTimer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync();
    }

    async Task PollAsync()
    {
        if (_timer is null) return;
        while (await _timer.WaitForNextTickAsync())
        {
            await Refresh();
            await InvokeAsync(StateHasChanged);
            // Stop polling when nothing is active and no live stats remain
            if (!jobs.Any(j => j.Status is DownloadStatus.Pending or DownloadStatus.Downloading)
                && Queue.ActiveStats.Count == 0)
                _timer.Dispose();
        }
    }

    async Task Refresh() => jobs = (await Queue.GetAllAsync()).ToList();

    async Task Delete(Guid id)
    {
        await Queue.DeleteAsync(id);
        await Refresh();
        // Always restart polling to catch the deletion taking effect
        _timer?.Dispose();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync();
    }

    static string FormatRate(double bytesPerSec) =>
        bytesPerSec < 1 ? "0 B/s" : $"{((long)bytesPerSec).Bytes().Humanize("#.#")}/s";

    public void Dispose() => _timer?.Dispose();
}
