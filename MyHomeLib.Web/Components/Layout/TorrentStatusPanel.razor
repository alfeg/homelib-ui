@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject DownloadQueueService Queue
@implements IDisposable
@using Humanizer

@if (Queue.IsEnabled)
{
    <MudPaper Elevation="1" Class="px-4 py-2 mb-3 mt-2">
        <div class="status-toolbar d-flex flex-wrap align-items-center gap-2">
            <MudText Typo="Typo.subtitle2" Class="mb-0">TorrServe</MudText>

            @if (!string.IsNullOrWhiteSpace(_stats?.TorrServVersion))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-0">@_stats.TorrServVersion</MudText>
            }

            @if (_stats is null)
            {
                <MudChip T="string" Color="Color.Default" Size="Size.Small">Connecting…</MudChip>
            }
            else if (!_stats.IsConnected)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Warning">Unreachable</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">Connected</MudChip>

                @if (!string.IsNullOrWhiteSpace(_stats.State) && _stats.State != "Connected")
                {
                    <MudChip T="string" Size="Size.Small">@_stats.State</MudChip>
                }

                @if (_stats.DownloadSpeed > 0 || _stats.UploadSpeed > 0)
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.SwapVert"
                             aria-label="Download / Upload speed">
                        ↓ @FormatSpeed(_stats.DownloadSpeed) &nbsp; ↑ @FormatSpeed(_stats.UploadSpeed)
                    </MudChip>
                }

                @if (!string.IsNullOrWhiteSpace(_stats.BitRate))
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Videocam" aria-label="Bit rate">
                        @_stats.BitRate
                    </MudChip>
                }

                @if (_stats.TotalPeers > 0)
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Group"
                             aria-label="Active / total peers (seeders)">
                        @_stats.ActivePeers/@_stats.TotalPeers
                        @if (_stats.ConnectedSeeders > 0)
                        {
                            <span class="ml-1">🌱 @_stats.ConnectedSeeders</span>
                        }
                    </MudChip>
                }

                @if (_cachePct.HasValue)
                {
                    <div class="status-cache d-flex align-items-center gap-1" title="@_cacheTitle">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                        <MudProgressLinear Color="Color.Info" Value="@_cachePct.Value" Class="status-cache-progress" Style="height:8px" />
                        <MudText Typo="Typo.caption" Class="mb-0 status-cache-percent">@_cachePct%</MudText>
                    </div>
                }

                @if (_stats.ActiveReaders > 0)
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.PlayArrow"
                             aria-label="Active stream readers">@_stats.ActiveReaders</MudChip>
                }
            }

            @if (Queue.ActiveDownloadCount > 0)
            {
                <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    @Queue.ActiveDownloadCount download@(Queue.ActiveDownloadCount > 1 ? "s" : "")
                </MudChip>
            }

            @if (_stats?.IsConnected == true)
            {
                <MudIconButton Icon="@(_showDetails ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small"
                               Class="ml-auto"
                               aria-label="@(_showDetails ? "Show less" : "Show more")"
                               OnClick="ToggleDetails" />
            }
        </div>

        @if (_showDetails && _stats?.IsConnected == true)
        {
            <MudDivider Class="my-2" />
            <MudGrid Spacing="2" Class="mt-1">
                <StatCell Label="⬇ Download" Value="@FormatSpeed(_stats.DownloadSpeed)" />
                <StatCell Label="⬆ Upload" Value="@FormatSpeed(_stats.UploadSpeed)" />
                <StatCell Label="Peers (active/total)" Value="@($"{_stats.ActivePeers}/{_stats.TotalPeers}")" />
                <StatCell Label="Half-open" Value="@_stats.HalfOpenPeers.ToString()" />
                <StatCell Label="Pending" Value="@_stats.PendingPeers.ToString()" />
                <StatCell Label="Seeders" Value="@_stats.ConnectedSeeders.ToString()" />
                @if (_stats.TorrentSize > 0)
                {
                    <StatCell Label="Loaded" Value="@_stats.LoadedSize.Bytes().Humanize()" />
                    <StatCell Label="Total size" Value="@_stats.TorrentSize.Bytes().Humanize()" />
                    @if (_stats.PreloadSize > 0)
                    {
                        <StatCell Label="Preloaded" Value="@($"{_stats.PreloadedBytes.Bytes().Humanize()} / {_stats.PreloadSize.Bytes().Humanize()}")" />
                    }
                }
                @if (_stats.CacheCapacity > 0)
                {
                    <StatCell Label="Cache" Value="@($"{_stats.CacheFilled.Bytes().Humanize()} / {_stats.CacheCapacity.Bytes().Humanize()}")" />
                    <StatCell Label="Pieces" Value="@_stats.CachedPieces.ToString()" />
                }
                @if (_stats.ActiveReaders > 0)
                {
                    <StatCell Label="Readers" Value="@_stats.ActiveReaders.ToString()" />
                }
                @if (_stats.DurationSeconds > 0)
                {
                    <StatCell Label="Active" Value="@TimeSpan.FromSeconds(_stats.DurationSeconds).Humanize()" />
                }
                @if (!string.IsNullOrWhiteSpace(_stats.BitRate))
                {
                    <StatCell Label="Bit rate" Value="@_stats.BitRate" />
                }
                @if (_stats.BytesRead > 0)
                {
                    <StatCell Label="Bytes read" Value="@_stats.BytesRead.Bytes().Humanize()" />
                    <StatCell Label="Useful" Value="@_stats.BytesReadUseful.Bytes().Humanize()" />
                }
                @if (_stats.BytesWritten > 0)
                {
                    <StatCell Label="Bytes written" Value="@_stats.BytesWritten.Bytes().Humanize()" />
                }
                @if (_stats.ChunksRead > 0)
                {
                    <StatCell Label="Chunks" Value="@($"{_stats.ChunksReadUseful} useful / {_stats.ChunksReadWasted} wasted")" />
                }
                @if (_stats.PiecesDirtiedGood + _stats.PiecesDirtiedBad > 0)
                {
                    <StatCell Label="Pieces dirty" Value="@($"{_stats.PiecesDirtiedGood} good / {_stats.PiecesDirtiedBad} bad")" />
                }
            </MudGrid>
        }
    </MudPaper>
}

@code {
    TorrentStats? _stats;
    PeriodicTimer? _timer;
    bool _showDetails;
    int? _cachePct;
    string? _cacheTitle;

    protected override void OnInitialized()
    {
        if (!Queue.IsEnabled) return;
        _stats = Queue.LibraryStats;
        if (_stats is not null)
            (_cachePct, _cacheTitle) = GetCacheDisplay(_stats);
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = PollAsync();
    }

    async Task PollAsync()
    {
        if (_timer is null) return;
        while (true)
        {
            _stats = Queue.LibraryStats;
            if (_stats is not null)
                (_cachePct, _cacheTitle) = GetCacheDisplay(_stats);
            await InvokeAsync(StateHasChanged);

            if (!await _timer.WaitForNextTickAsync())
                break;
        }
    }

    void ToggleDetails() => _showDetails = !_showDetails;

    static string FormatSpeed(double bytesPerSec)
    {
        if (bytesPerSec < 1024) return $"{bytesPerSec:F0} B/s";
        if (bytesPerSec < 1024 * 1024) return $"{bytesPerSec / 1024:F1} KB/s";
        return $"{bytesPerSec / (1024 * 1024):F1} MB/s";
    }

    static (int? Pct, string? Title) GetCacheDisplay(TorrentStats s)
    {
        if (s.TorrentSize > 0)
            return ((int)Math.Round(100.0 * s.LoadedSize / s.TorrentSize),
                    $"{s.LoadedSize.Bytes().Humanize()} / {s.TorrentSize.Bytes().Humanize()} cached");
        if (s.CacheCapacity > 0)
            return ((int)Math.Round(100.0 * s.CacheFilled / s.CacheCapacity),
                    $"Cache: {s.CacheFilled.Bytes().Humanize()} / {s.CacheCapacity.Bytes().Humanize()}");
        return (null, null);
    }

    public void Dispose() => _timer?.Dispose();
}

