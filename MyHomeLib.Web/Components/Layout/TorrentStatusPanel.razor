@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject DownloadQueueService Queue
@implements IDisposable

@if (Queue.IsEnabled)
{
    <div class="torrent-status px-3 py-2 bg-body-tertiary border rounded small text-muted mt-3 mb-2">
        <div class="d-flex flex-wrap align-items-center gap-3">
            <span class="fw-semibold text-body">🔗 TorrServe</span>

            @if (_stats is null)
            {
                <span class="fst-italic">Connecting…</span>
            }
            else if (!_stats.IsConnected)
            {
                <span class="text-danger fw-semibold">⚠ Unreachable</span>
            }
            else
            {
                <span class="text-success">● Connected</span>
                @if (!string.IsNullOrWhiteSpace(_stats.State) && _stats.State != "Connected")
                {
                    <span class="text-muted">@_stats.State</span>
                }
            }

            @if (Queue.ActiveDownloadCount > 0)
            {
                <span>
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    @Queue.ActiveDownloadCount download@(Queue.ActiveDownloadCount > 1 ? "s" : "") in progress
                </span>
            }
        </div>
    </div>
}

@code {
    TorrentStats? _stats;
    PeriodicTimer? _timer;

    protected override void OnInitialized()
    {
        if (!Queue.IsEnabled) return;
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = PollAsync();
    }

    async Task PollAsync()
    {
        if (_timer is null) return;
        while (await _timer.WaitForNextTickAsync())
        {
            _stats = Queue.LibraryStats;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => _timer?.Dispose();
}
