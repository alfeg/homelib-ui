@inherits LayoutComponentBase
@inject LibraryService Library
@inject DownloadQueueService Queue

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-2" />
        <MudText Typo="Typo.h6" Class="mr-3">MyHomeLib</MudText>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-none d-sm-block">@Subtitle</MudText>
        }
        <MudSpacer />
        <MudButton Href="/" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Search">Search</MudButton>
        @if (Queue.IsEnabled)
        {
            <MudButton Href="/downloads" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Download">Downloads</MudButton>
        }
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            <TorrentStatusPanel />
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    string Subtitle => Library.Metadata.Description?
        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .FirstOrDefault() ?? string.Empty;

    static readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976d2",
            Secondary = "#424242",
            AppbarBackground = "#1565c0",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#90caf9",
            AppbarBackground = "#0d47a1",
        },
    };
}
