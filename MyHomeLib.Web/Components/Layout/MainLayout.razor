@inherits LayoutComponentBase

<div class="container-xl py-4">
    <header class="mb-4 border-bottom pb-3">
        <span class="fs-4 fw-semibold">📚 MyHomeLib</span>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <span class="text-muted ms-2 small">@Subtitle</span>
        }
    </header>
    @Body
</div>

@code {
    [Inject] LibraryService Library { get; set; } = default!;

    // collection.info is multi-line; show only the first meaningful line.
    string Subtitle => Library.Metadata.Description?
        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .FirstOrDefault() ?? string.Empty;
}
