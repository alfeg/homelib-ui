{
  "ReverseProxy": {
    "Routes": {
      "vite": {
        "ClusterId": "vite",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "vite": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5173/"
          }
        }
      }
    }
  }
}
