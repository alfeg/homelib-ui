        <PackageReference Include="Parquet.Net" Version="4.23.4" />
        <PackageReference Include="Spectre.Console" Version="0.48.0" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\MyHomeLib.Library\MyHomeLib.Library.csproj" />
    </ItemGroup>

</Project>
