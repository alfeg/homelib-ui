@inherits LayoutComponentBase
@inject LibraryAccessor library;
<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="25">
        <MudIconButton Icon="@Icons.Material.Outlined.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudText Typo="Typo.h6" Class="ml-4">Homelib Web UI</MudText>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.Xs" Invert="true">
            <MudText Typo="Typo.subtitle2">Homelib Web UI</MudText>
        </MudHidden>

        <MudSpacer />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="25" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>

        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
            @if (library.Library.IsIndexing)
            {
                <MudAlert Severity="Severity.Warning">Library index is in progress. @library.Library.BooksAdded of @library.Library.BooksRead</MudAlert>
            }
            @Body
        </MudContainer>

    </MudMainContent>
</MudLayout>


@code {
    private MudBlazorAdminDashboard _theme = new();

    public bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override void OnInitialized()
    {
        StateHasChanged();
    }

    Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        if (library.Library.IsIndexing)
        {
            timer = new Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    StateHasChanged();
                    if (!library.Library.IsIndexing)
                    {                        
                        timer.Dispose();
                    }
                });
            }, null, 1000, 1000);
        }
    }
}