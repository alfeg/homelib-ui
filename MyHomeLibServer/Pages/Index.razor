@page "/"
@inject LibrarySearch search;
@inherits OwningComponentBase
@inject NavigationManager navManager
@inject IDbContextFactory<LibDbContext> dbContextFactory;
<PageTitle>Index</PageTitle>

<MudGrid>
    <MudDrawer Open="true" Elevation="25" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudItem xs="12" sm="6" md="6">
        <MudPaper Class="pa-4" Height="94px">
            <MudTextField Value="Search" Label="Search" Variant="Variant.Outlined"
                          DebounceInterval="100"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Filled.Search" AdornmentColor="Color.Secondary"
                          TextChanged="SetSearch" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="12" md="12">
        <MudTable @ref="table" RowsPerPage="25" ServerData="SearchData" Breakpoint="Breakpoint.Sm" Virtualize="true" Dense="true" FixedHeader="true" Loading="isLoading">
            <HeaderContent>
                <MudTh class="w-25">Authors</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Genre</MudTh>
                <MudTh>Series</MudTh>
                <MudTh>Date</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Authors" class="w-25" Style="word-wrap: anywhere">@string.Join(", ", context.Authors)</MudTd>
                <MudTd DataLabel="Title">@context.Title</MudTd>
                <MudTd DataLabel="Genre">@context.Genre</MudTd>
                <MudTd DataLabel="Series">@context.Series</MudTd>
                <MudTd DataLabel="Date">@context.Date</MudTd>
                <MudTd DataLabel="Action">
                    <MudLink Target="_blank" Href="@($"api/download/{@context.Id}")">@context.Ext</MudLink>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    [SupplyParameterFromQuery(Name = "search")]
    [Parameter]
    public string? Search { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    [Parameter]
    public long? Page { get; set; }

    List<BookItem> books = new();

    bool isLoading;
    private MudTable<BookItem> table;
    bool isRendered = false;
    protected override async Task OnParametersSetAsync()
    {
        if (table != null)
        {
            await table.ReloadServerData();
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        isRendered = true;
        return Task.CompletedTask;
    }

    void SetSearch(string search)
    {
        var uri = navManager.GetUriWithQueryParameter("search", !string.IsNullOrWhiteSpace(search) ? search : null);
        if (navManager.Uri != uri)
        {
            navManager.NavigateTo(uri);
        }
    }

    private async Task<TableData<BookItem>> SearchData(TableState state)
    {
        isLoading = true;

        try
        {
            await using var db = await dbContextFactory.CreateDbContextAsync();
            var query = search.Search(Search, db, CancellationToken.None);

            var total = await query.CountAsync();

            var result = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();

            return new TableData<BookItem>()
                {
                    Items = result,
                    TotalItems = total
                };
        }
        finally
        {
            isLoading = false;
        }
    }

}